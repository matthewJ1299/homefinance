# Auth (required for production)
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Database (optional, defaults to ./data/sqlite.db)
# DB_PATH=./data/sqlite.db

# Seed (optional)
# SEED_USER_PASSWORD=ChangeMe123!
# SEED_USER1_EMAIL=user1@homefinance.local
# SEED_USER2_EMAIL=user2@homefinance.local
# SEED_USER1_NAME=User One
# SEED_USER2_NAME=User Two

# Local only: add 3 months of sample transactions and income for testing. Do not set in production.
# SEED_SAMPLE_DATA=true
AUTH_SECRET=dev-secret-change-in-production
SEED_SAMPLE_DATA=true