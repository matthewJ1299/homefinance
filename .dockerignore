# Dependencies (installed inside the container)
node_modules
.pnp
.pnp.js

# Build output (rebuilt inside the container)
.next
out

# Git
.git
.gitignore
.gitattributes

# Env and secrets
.env
.env.*
!.env.example

# Local data (must not be baked into the image)
data

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# IDE and OS
.idea
.vscode
.DS_Store

# Documentation (not needed in the image)
*.md
!README.md

# Testing
coverage
*.test.*
*.spec.*

# TypeScript build info
*.tsbuildinfo
next-env.d.ts
